# ---------------------------------------------------------------------------
# Public site URL
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://globalhoopstats.es

# ---------------------------------------------------------------------------
# Secret to protect /api/cron/* endpoints — generate with:
#   node -e "console.log(crypto.randomBytes(24).toString('base64'))"
# ---------------------------------------------------------------------------
