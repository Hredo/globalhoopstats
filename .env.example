# Copy this file to .env.local and fill in the values you need.
# Never commit .env or .env.local files.
# All values are optional for local dev; sensible defaults are applied.
# In PRODUCTION, SESSION_SECRET (and ideally ENCRYPTION_KEY) are REQUIRED — the
# app refuses to boot otherwise. See DEPLOY.md for the full Netlify checklist.

# Neon Postgres connection string. In production (serverless) prefer the POOLED
# endpoint — its host contains "-pooler" (e.g. ep-xxx-pooler.region.aws.neon.tech)
# — to avoid exhausting direct connections. Keep ?sslmode=require for TLS.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Secret used to sign session tokens (HMAC). Must be >=32 chars and unique.
# REQUIRED in production. Generate with:
#   node -e "console.log(crypto.randomBytes(32).toString('base64'))"
# SESSION_SECRET=

# YouTube Data API v3 — https://console.cloud.google.com
# Needed only for the highlights feature on player profiles.
YOUTUBE_API_KEY=

# Google Search Console site verification code.
# Set to your verification string (e.g. "google-site-verification=...") so
# <meta name="google-site-verification"> appears on every page.
# Optional — omit to skip the meta tag entirely.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools (Microsoft) site verification code.
# Set to the value from the <meta name="msvalidate.01" content="..."> tag so
# that meta tag appears on every page.
# Optional — omit to skip the meta tag entirely.
# NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Public site URL — used as canonical base for sitemap, robots, OpenGraph and
# JSON-LD. In production set to "https://globalhoopstats.es" (NOT .com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret to protect /api/cron/* endpoints — only required if you wire up
# the ingestion cron. Generate with: node -e "console.log(crypto.randomBytes(24).toString('base64'))"
# CRON_SECRET=

# ─── Cloudflare Analytics (admin "Tráfico" panel) ────────────────────────────
# Lets the admin panel show real traffic (requests, status codes, bandwidth,
# threats blocked, unique visitors, countries) WITHOUT opening the Cloudflare
# dashboard. Both optional — if unset the Tráfico tab shows a setup notice.
#
# 1. Cloudflare dashboard → My Profile → API Tokens → Create Token →
#    "Create Custom Token". Permissions: Account/Zone → Analytics → Read.
#    Scope it to the globalhoopstats.es zone. Copy the token here.
# 2. Zone ID: dashboard → select globalhoopstats.es → Overview → right sidebar
#    "Zone ID". Copy it here.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=

# Number of trusted reverse proxies in front of the app. Used to derive the
# real client IP from X-Forwarded-For for rate-limiting / brute-force defense
# (the real IP is the Nth value from the RIGHT — the left-most entry is
# attacker-controlled). Default 1 (single platform edge proxy). Increase only
# if your hosting adds more hops (e.g. a CDN in front of the app server).
# TRUSTED_PROXY_HOPS=1

# Encryption key for user-provided AI API keys (AES-256-GCM, at rest).
# Optional in dev (derived from SESSION_SECRET). REQUIRED in production.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
# ENCRYPTION_KEY=

# ─── Transactional email ─────────────────────────────────────────────────────
# All app email (welcome, password reset, 2FA codes, contact, waitlist) goes
# through src/lib/email. Transport priority: Resend → Gmail SMTP → console.log.

# Resend (PRIMARY) — https://resend.com · free tier 3,000 emails/month.
# 1. Create an API key (Resend dashboard → API Keys).
# 2. Verify the globalhoopstats.es domain (Resend → Domains → Add Domain) and
#    add the DKIM/SPF DNS records it gives you (these live in Hostinger DNS).
#    Until the domain is verified, Resend can only deliver to your own address.
# RESEND_API_KEY=

# Gmail SMTP (FALLBACK) — used only if RESEND_API_KEY is unset. Sends literally
# as globalhoopstats@gmail.com (~500/day limit).
# 1. Enable 2FA on the Google account · 2. https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail" · 4. paste it here:
# GMAIL_APP_PASSWORD=

# Sender ("from") for all transactional email. With Resend this MUST be an
# address on a domain verified in Resend. Defaults to no-reply@globalhoopstats.es.
# Replies are routed to the public contact address (globalhoopstats@gmail.com).
# AUTH_EMAIL_FROM=no-reply@globalhoopstats.es

# Local LLM (Ollama) — install from https://ollama.com/download
# The AI advisor calls http://localhost:11434/v1/chat/completions by default.
# Pull a model with: ollama pull llama3.1:8b
#
# Optional overrides:
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1:8b
#
# Other good Spanish-capable models:
#   qwen2.5:7b       — excellent Spanish, 4.7GB
#   gemma2:9b        — strong reasoning, 5.4GB
#   mistral          — fast, 4.1GB
#   llama3.2:3b      — light, 2GB, weaker reasoning
#
# Default AI engine (anonymous users) — uncomment in production to let all users
# use AI features without bringing their own API key. The app falls back to this
# when a user hasn't configured a provider in their account.
# AI_DEFAULT_PROVIDER=groq
# AI_DEFAULT_MODEL=llama-3.3-70b-versatile
# AI_DEFAULT_API_KEY=gsk_...

# ─────────────────────────────────────────────────────────────────────────────
# Data ingestion / scraping (optional — sensible defaults apply)
# ─────────────────────────────────────────────────────────────────────────────
# The crawler identifies itself honestly (see /bot). Override the User-Agent
# string here if the contact URL/address changes — keep it identifiable, do NOT
# masquerade as a browser. Default:
#   GlobalHoopStatsBot/1.0 (+https://globalhoopstats.es/bot; data@globalhoopstats.es)
# SCRAPER_USER_AGENT=

# Minimum gap (ms) between requests to the SAME host. Higher = politer/slower.
# Default 1200.
# SCRAPER_MIN_HOST_INTERVAL_MS=1200

# Incoming webhook (Slack/Discord-style) the quality gate posts to when it
# BLOCKS a sync because a scrape looked broken. If unset, blocks are logged only.
# SCRAPER_ALERT_WEBHOOK=

# The scheduled sync is triggered externally: a Hostinger cron job curls
# POST /api/cron/sync (protected by CRON_SECRET above) — see docs/SYNC.md.
